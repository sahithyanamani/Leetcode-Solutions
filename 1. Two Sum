
class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        #brute force

        '''for i in range(len(nums)):
            for j in range(i+1, len(nums)):
                if nums[i]+nums[j] == target:
                    return [i,j]
        return
        tc= o(n*n)
        sc(1)'''

        #hashmap

        targetMap ={}

        for i, n in enumerate(nums):
            diff = target-n
            if diff in targetMap:
                return [targetMap[diff],i]
            targetMap[n]=i

        #tc=o(n), sc=o(n)
        
